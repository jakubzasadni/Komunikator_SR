@startuml

!theme plain
skinparam backgroundColor #FAFAFA
skinparam nodeBackgroundColor #D6EAF8
skinparam nodeBorderColor #2980B9
skinparam componentBackgroundColor #D5E8D4
skinparam componentBorderColor #82B366
skinparam databaseBackgroundColor #FFF2CC
skinparam databaseBorderColor #D6B656
skinparam arrowColor #2C3E50
skinparam packageBackgroundColor #F8F9FA
skinparam packageBorderColor #AEB6BF
skinparam interfaceBackgroundColor #FADBD8
skinparam interfaceBorderColor #E74C3C
skinparam linetype ortho

title Komunikator SR — Diagram Komponentów i Wdrożenia

' ─────────────────────────────────────────────
' PRZEGLĄDARKA
' ─────────────────────────────────────────────

actor "Użytkownik" as EndUser

node "Przeglądarka\n(Chrome / Firefox)" as Browser {
    component [React SPA\nVite dev server\n:5173] as SPA
}

EndUser --> Browser

' ─────────────────────────────────────────────
' DOCKER HOST
' ─────────────────────────────────────────────

node "Docker Host\n(docker-compose)" as DockerHost {

    ' ─────────────────────────────────────────
    ' KONTENER: FRONTEND
    ' ─────────────────────────────────────────
    node "frontend\nnode:20-alpine  :5173" as FE {

        package "React SPA" {
            component [App.jsx\n(Router)] as App
            component [LoginPage] as Login
            component [RegisterPage] as Register
            component [ChatPage] as Chat

            component [AuthContext\n(JWT + user state)] as AuthCtx
            component [SocketContext\n(WebSocket state)] as SockCtx
            component [api.js\n(Axios + Bearer)] as Api
        }

        App --> Login
        App --> Register
        App --> Chat
        Chat --> AuthCtx
        Chat --> SockCtx
        Login --> Api
        Register --> Api
        AuthCtx --> Api
        SockCtx --> AuthCtx
    }

    ' ─────────────────────────────────────────
    ' KONTENER: BACKEND
    ' ─────────────────────────────────────────
    node "backend\npython:3.12-slim  :5000" as BE {

        package "Flask Application" {

            package "REST API" {
                component [/api/auth/*\nAuthRoutes] as AuthBP
                component [/api/users/*\nUserRoutes] as UserBP
                component [/api/rooms/*\nRoomRoutes] as RoomBP
                component [/api/messages/*\nMessageRoutes] as MsgBP
            }

            package "WebSocket" {
                component [SocketIO Events\nevents.py] as Events
                component [SessionStore\n(in-memory)\nuser_id → {socket_ids}] as SessionStore
            }

            package "Modele (SQLAlchemy)" {
                component [User] as UserM
                component [Room] as RoomM
                component [RoomMember] as MemberM
                component [Message] as MessageM
            }

            component [Flask-JWT-Extended] as JWT
            component [Flask-Bcrypt] as Bcrypt
            component [Flask-Migrate\n(Alembic)] as Migrate

            AuthBP  --> JWT
            AuthBP  --> Bcrypt
            AuthBP  --> UserM
            UserBP  --> UserM
            UserBP  --> SessionStore
            RoomBP  --> RoomM
            RoomBP  --> MemberM
            MsgBP   --> MessageM
            MsgBP   --> MemberM

            Events --> SessionStore
            Events --> MessageM
            Events --> MemberM
        }
    }

    ' ─────────────────────────────────────────
    ' KONTENER: DATABASE
    ' ─────────────────────────────────────────
    node "db\npostgres:16-alpine  :5432" as DB {
        database "PostgreSQL\nkomunikator_db" as PG {
            component [users] as TUsers
            component [rooms] as TRooms
            component [room_members] as TMembers
            component [messages] as TMessages
        }
    }

    storage "Docker Volume\npgdata" as PgVolume
    DB ..> PgVolume : persists

    ' ─────────────────────────────────────────
    ' POŁĄCZENIA MIĘDZY KONTENERAMI
    ' ─────────────────────────────────────────
    BE --> DB : SQLAlchemy\nDATABASE_URL
}

' ─────────────────────────────────────────────
' POŁĄCZENIA ZEWNĘTRZNE
' ─────────────────────────────────────────────

Browser --> FE : HTTP :5173
Api --> BE : REST HTTP/JSON\nAuthorization: Bearer JWT
SockCtx --> BE : WebSocket\nSocket.IO protocol\ntoken w query param

note bottom of SessionStore
  In-memory:
  { user_id: set(socket_id, ...) }
  Wielosesyjność (multi-tab)
end note

note bottom of PG
  Migracje przez Flask-Migrate
  uruchamiane w entrypoint.sh:
  flask db upgrade
end note

@enduml
