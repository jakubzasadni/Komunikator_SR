@startuml Komunikator_SR - Use Case Diagram

!theme plain
skinparam backgroundColor #FAFAFA
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #E8F4FD
skinparam usecaseBorderColor #2980B9
skinparam packageBackgroundColor #EBF5FB
skinparam packageBorderColor #85C1E9
skinparam arrowColor #2C3E50
skinparam noteBackgroundColor #FEF9E7
skinparam noteBorderColor #F0B429

title Komunikator SR — Diagram Przypadków Użycia

' ─────────────────────────────────────────────
' AKTORZY
' ─────────────────────────────────────────────

actor "Gość\n(niezalogowany)" as Guest #LightGray
actor "Użytkownik\n(zalogowany)" as User #5DADE2
actor "PostgreSQL\n(Baza Danych)" as DB #90EE90
actor "Socket.IO\n(Serwer WS)" as WS #FFB347

' ─────────────────────────────────────────────
' MODUŁ: AUTENTYKACJA
' ─────────────────────────────────────────────

package "Autentykacja" {
    usecase "UC01\nRejestracja konta" as UC01
    usecase "UC02\nLogowanie" as UC02
    usecase "UC03\nWylogowanie" as UC03
    usecase "UC04\nWalidacja tokenu JWT" as UC04
}

' ─────────────────────────────────────────────
' MODUŁ: WIADOMOŚCI PRYWATNE
' ─────────────────────────────────────────────

package "Czat Prywatny (1:1)" {
    usecase "UC05\nWysłanie wiadomości\nprywatnej" as UC05
    usecase "UC06\nOdbiór wiadomości\nprywatnej" as UC06
    usecase "UC07\nPrzeglądanie historii\nrozmowy" as UC07
    usecase "UC08\nPowiadomienie\n\"pisze...\"" as UC08
    usecase "UC09\nPotwierdzenie\ndostarczenia (ACK)" as UC09
}

' ─────────────────────────────────────────────
' MODUŁ: POKOJE GRUPOWE
' ─────────────────────────────────────────────

package "Pokoje Grupowe" {
    usecase "UC10\nUtworzenie pokoju" as UC10
    usecase "UC11\nDołączenie do pokoju" as UC11
    usecase "UC12\nWysłanie wiadomości\ndo pokoju" as UC12
    usecase "UC13\nOdbiór wiadomości\npokojowej" as UC13
    usecase "UC14\nPrzeglądanie historii\npokoju" as UC14
    usecase "UC15\nOpuszczenie pokoju\n(Socket.IO room)" as UC15
}

' ─────────────────────────────────────────────
' MODUŁ: OBECNOŚĆ I STATUS
' ─────────────────────────────────────────────

package "Obecność i Kontakty" {
    usecase "UC16\nPrzeglądanie listy\nużytkowników" as UC16
    usecase "UC17\nPodgląd statusu\nonline/offline" as UC17
    usecase "UC18\nPowiadomienie o zmianie\nstatusu (broadcast)" as UC18
}

' ─────────────────────────────────────────────
' RELACJE: GOŚĆ
' ─────────────────────────────────────────────

Guest --> UC01
Guest --> UC02

' ─────────────────────────────────────────────
' RELACJE: UŻYTKOWNIK ZALOGOWANY
' ─────────────────────────────────────────────

User --> UC03
User --> UC05
User --> UC06
User --> UC07
User --> UC08
User --> UC10
User --> UC11
User --> UC12
User --> UC13
User --> UC14
User --> UC15
User --> UC16
User --> UC17

' ─────────────────────────────────────────────
' RELACJE: SYSTEMY ZEWNĘTRZNE
' ─────────────────────────────────────────────

DB --> UC01 : <<persists>>
DB --> UC02 : <<verifies>>
DB --> UC07 : <<persists>>
DB --> UC05 : <<persists>>
DB --> UC12 : <<persists>>
DB --> UC14 : <<persists>>

WS --> UC06 : <<delivers>>
WS --> UC09 : <<confirms>>
WS --> UC13 : <<broadcasts>>
WS --> UC18 : <<broadcasts>>

' ─────────────────────────────────────────────
' INCLUDE / EXTEND
' ─────────────────────────────────────────────

UC02 ..> UC04 : <<include>>
UC05 ..> UC04 : <<include>>
UC10 ..> UC04 : <<include>>
UC11 ..> UC04 : <<include>>
UC12 ..> UC04 : <<include>>
UC16 ..> UC04 : <<include>>

UC05 ..> UC09 : <<extend>>\n[odbiorca online]
UC18 ..> UC17 : <<extend>>\n[przy connect/disconnect]

UC11 ..> UC10 : <<extend>>\n[nowy pokój]

note right of UC04
  Każdy chroniony endpoint
  wymaga ważnego tokenu JWT
  w nagłówku Authorization
end note

note bottom of UC09
  Server ustawia
  Message.delivered = True
  i emituje ACK do nadawcy
end note

note bottom of UC18
  Broadcast do WSZYSTKICH
  połączonych klientów
  przy każdej zmianie statusu
end note

@enduml
